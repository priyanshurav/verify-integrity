{
  "name": "verify-integrity",
  "version": "1.2.0",
  "bin": {
    "verify-integrity": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "description": "A modern, zero-dependency CLI tool to easily verify file hashes.",
  "license": "MIT",
  "homepage": "https://github.com/priyanshurav/verify-integrity#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priyanshurav/verify-integrity.git"
  },
  "bugs": {
    "url": "https://github.com/priyanshurav/verify-integrity/issues"
  },
  "author": {
    "name": "Priyanshu Rav",
    "url": "https://github.com/priyanshurav/"
  },
  "type": "module",
  "scripts": {
    "pretest": "pnpm run build",
    "test": "node --import tsx --test",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=18.11.0"
  },
  "keywords": [
    "cli",
    "hash",
    "checksum",
    "verify",
    "integrity",
    "crypto",
    "file-hash",
    "sha256",
    "sha512",
    "md5",
    "shasum",
    "streaming"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  }
}
